# =============================================
# .gitignore — Next.js Learning Repository
# =============================================

# ----- Dependencies -----
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ----- Next.js -----
.next/
out/

# ----- Production build -----
build/
dist/

# ----- Testing -----
coverage/

# ----- Environment variables -----
.env
.env.*
!.env.example
!.env.local.example

# ----- Debug logs -----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ----- TypeScript -----
*.tsbuildinfo
next-env.d.ts

# ----- Vercel -----
.vercel

# ----- OS generated files -----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ----- IDE / Editor -----
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# ----- Misc -----
*.pem
*.log
